{
  "name": "elysia-vue-query",
  "private": true,
  "license": "MIT",
  "author": "Saku Shiina <shiinasaku@proton.me>",
  "workspaces": [
    "packages/*",
    "playground/*",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm --filter './packages/*' run build",
    "build:core": "pnpm --filter @elysia-vue-query/core run build",
    "build:vue": "pnpm --filter @elysia-vue-query/vue run build",
    "check": "vp check && pnpm run typecheck",
    "lint": "vp lint",
    "test": "vp test run",
    "test:watch": "vp test",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/vue/tsconfig.json",
    "playground:api": "pnpm --filter @playground/api run dev",
    "playground:vue": "pnpm --filter @playground/vue-app run dev",
    "playground:nuxt": "pnpm --filter @playground/nuxt-app run dev",
    "docs:dev": "pnpm --filter @elysia-vue-query/docs run dev",
    "docs:build": "pnpm --filter @elysia-vue-query/docs run build",
    "docs:preview": "pnpm --filter @elysia-vue-query/docs run preview",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish --provenance",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "publint": "^0.3.18",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
