{
  "name": "@elysia-vue-query/vue",
  "version": "0.1.0",
  "description": "Vue 3 composables (useQuery, useMutation, prefetch) for elysia-vue-query",
  "type": "module",
  "author": "Saku Shiina <shiinasaku@proton.me>",
  "license": "MIT",
  "homepage": "https://elysia-vue.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/elysia-vue-query/elysia-vue-query.git",
    "directory": "packages/vue"
  },
  "keywords": ["elysia", "eden", "vue", "vue3", "tanstack-query", "vue-query", "typescript", "ssr"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@elysia-vue-query/core": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "^5",
    "vue": "^3"
  },
  "devDependencies": {
    "@tanstack/vue-query": "^5.92.9",
    "vue": "^3.5.29",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  }
}
