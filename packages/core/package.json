{
  "name": "@elysia-vue-query/core",
  "version": "1.0.0",
  "description": "Proxy engine, key builders, and serialization for elysia-vue-query",
  "keywords": [
    "eden",
    "elysia",
    "tanstack-query",
    "typescript",
    "vue",
    "vue-query"
  ],
  "homepage": "https://elysia-vue.pages.dev",
  "license": "MIT",
  "author": "Saku Shiina <shiinasaku@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elysia-vue-query/elysia-vue-query.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  }
}
